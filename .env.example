# =============================================================================
# openclaw-lmstudio environment configuration
# Copy this file to .env and edit the values below.
# =============================================================================

# --- Provider Selection ---
# Choose: lmstudio (default) or claude
PROVIDER=lmstudio

# --- LM Studio Settings (when PROVIDER=lmstudio) ---
LMSTUDIO_PORT=1234
LMSTUDIO_MODEL_ID=qwen3-8b
LMSTUDIO_MODEL_NAME=Local Model
LMSTUDIO_CONTEXT_WINDOW=32768
LMSTUDIO_MAX_TOKENS=4096

# --- Claude Settings (when PROVIDER=claude) ---
# ANTHROPIC_API_KEY=sk-ant-api03-...
# CLAUDE_MODEL=anthropic/claude-sonnet-4-5

# --- Workspace ---
WORKSPACE_PATH=./workspace

# =============================================================================
# Optional Dependencies
#
# OpenClaw skills rely on external tools that aren't in the base image.
# Enable the flags below to install them. All are disabled by default.
# =============================================================================

# --- Build-Time Dependencies (require `docker compose build` after changing) ---

# Chromium browser + X11/font libs (~400 MB). Needed for web browsing skills.
INSTALL_CHROMIUM=false

# ffmpeg (~80 MB). Needed for summarize, video-frames skills.
INSTALL_FFMPEG=false

# --- Runtime Dependencies (installed on container start, persist on .local volume) ---

# Go runtime (~150 MB download, once). Needed for blogwatcher skill.
INSTALL_GO=false

# uv Python package manager (~30 MB). Needed for mcporter skill.
INSTALL_UV=false

# npm global packages: clawhub, gifgrep. Needed for those skills.
INSTALL_NPM_GLOBALS=false

# Homebrew + OpenClaw tap (~500 MB). Installs brew, gogcli, sag, gh.
# Future skills that need new CLIs can just `brew install` them.
# Requires `docker compose build` after enabling.
INSTALL_HOMEBREW=false


# --- Skill dependencies: Brew packages (build-time) ---
# Space-separated list of Homebrew formulae installed during docker build.
# The steipete/tap is already tapped in the base image.
#
# Skill              | Brew formula
# -------------------|---------------------------
# camsnap            | steipete/tap/camsnap       (also set INSTALL_FFMPEG=true)
# gifgrep            | steipete/tap/gifgrep
# model-usage        | steipete/tap/codexbar
# peekaboo           | steipete/tap/peekaboo      (macOS-only, may not build on Linux)
# session-logs       | ripgrep
# tmux               | tmux
#
BREW_PACKAGES=steipete/tap/camsnap steipete/tap/gifgrep steipete/tap/codexbar tmux ripgrep

# --- Skill dependencies: npm packages (build-time) ---
# Space-separated list of npm packages installed globally during docker build.
#
# Skill              | npm package
# -------------------|---------------------------
# mcporter           | mcporter
# xurl               | @xdevplatform/xurl
# coding-agent       | @anthropic-ai/claude-code
# playwright-mcp     | @playwright/mcp
#
NPM_PACKAGES=mcporter @xdevplatform/xurl @anthropic-ai/claude-code @playwright/mcp
