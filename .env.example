# =============================================================================
# openclaw-lmstudio configuration
# =============================================================================
# Copy this file to .env and edit the values below.

# --- Provider Selection ---
# Choose your LLM backend: "lmstudio" (local, free) or "claude" (Anthropic API)
PROVIDER=lmstudio

# --- Claude Provider (only used when PROVIDER=claude) ---
# Your Anthropic API key (starts with sk-ant-api03-)
ANTHROPIC_API_KEY=
# Claude model to use (default: anthropic/claude-sonnet-4-5)
CLAUDE_MODEL=anthropic/claude-sonnet-4-5

# --- LM Studio Provider (only used when PROVIDER=lmstudio) ---
# The model ID as it appears in LM Studio (e.g., "qwen3-8b", "llama-4-scout")
LMSTUDIO_MODEL_ID=qwen3-8b
# Human-readable model name (shown in OpenClaw UI)
LMSTUDIO_MODEL_NAME=Qwen3 8B
# Port LM Studio listens on (default: 1234)
LMSTUDIO_PORT=1234
# Context window size supported by your model
LMSTUDIO_CONTEXT_WINDOW=32768
# Max output tokens per response
LMSTUDIO_MAX_TOKENS=4096

# --- Workspace ---
# Absolute path to the project directory you want OpenClaw to work on.
# This directory is bind-mounted into the container at /workspace.
WORKSPACE_PATH=./workspace
